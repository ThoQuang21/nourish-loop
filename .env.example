# Frontend env (Vite). Sao chép thành .env và điền giá trị thật.
# Chỉ biến có tiền tố VITE_ mới được expose ra client.

# URL backend API (mặc định nếu bỏ trống: http://localhost:3000/api)
VITE_API_URL="http://localhost:3000/api"

# Goong Maptiles key (để render bản đồ). Lấy ở https://goong.io
VITE_GOONG_MAPTILES_KEY=""
